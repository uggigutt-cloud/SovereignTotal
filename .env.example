# ─── Google Cloud Platform ────────────────────────────────────────────────────
# Set USE_VERTEX_AI=true to use Vertex AI (Gemini on GCP) instead of the public API.
USE_VERTEX_AI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west4

# Cloud Storage bucket for uploaded Norwegian legal documents
# Created with: gsutil mb -l europe-west4 gs://${GOOGLE_CLOUD_PROJECT}-sovereign-docs
GOOGLE_CLOUD_STORAGE_BUCKET=your-project-id-sovereign-docs

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For Cloud SQL via Cloud Run: use the Unix socket path format below.
# Omit entirely to fall back to the in-process PGLite (development/testing only).
#
# Cloud SQL (unix socket — used inside Cloud Run):
# DATABASE_URL=postgresql://sovereign:PASSWORD@/sovereign?host=/cloudsql/PROJECT:europe-west4:sovereign-db
#
# Local PostgreSQL:
# DATABASE_URL=postgresql://sovereign:PASSWORD@localhost:5432/sovereign
DATABASE_URL=

# ─── Google OAuth (NextAuth) ──────────────────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-32-char-secret-here

# The public URL of the application (no trailing slash)
# Development:
NEXTAUTH_URL=http://localhost:3000
# Production (Cloud Run):
# NEXTAUTH_URL=https://sovereign-app-XXXX-ew.a.run.app

# From GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ─── Gemini API (local development without Vertex AI) ────────────────────────
# Used when USE_VERTEX_AI is not set or false.
# Get from: https://ai.google.dev/gemini-api/docs/api-key
# GEMINI_API_KEY=your-gemini-api-key

# ─── GCP Resource Setup (one-time CLI commands) ───────────────────────────────
#
# Cloud SQL PostgreSQL 16:
#   gcloud sql instances create sovereign-db \
#     --database-version=POSTGRES_16 --tier=db-g1-small --region=europe-west4
#   gcloud sql databases create sovereign --instance=sovereign-db
#   gcloud sql users create sovereign --instance=sovereign-db --password=PASSWORD
#
# Cloud Storage bucket:
#   gsutil mb -l europe-west4 gs://${GOOGLE_CLOUD_PROJECT}-sovereign-docs
#
# Artifact Registry:
#   gcloud artifacts repositories create sovereign \
#     --repository-format=docker --location=europe-west4
#
# Secret Manager (repeat for each secret):
#   echo -n "VALUE" | gcloud secrets create sovereign-db-url --data-file=-
#   echo -n "VALUE" | gcloud secrets create sovereign-nextauth-secret --data-file=-
#   echo -n "VALUE" | gcloud secrets create sovereign-google-oauth-id --data-file=-
#   echo -n "VALUE" | gcloud secrets create sovereign-google-oauth-secret --data-file=-
#
# Cloud Build trigger:
#   gcloud builds submit --config cloudbuild.yaml
